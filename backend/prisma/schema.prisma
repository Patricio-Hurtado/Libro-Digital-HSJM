// Configuración básica
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql" // O mysql según tu preferencia
  //url      = env("DATABASE_URL")
}

// Agregamos este bloque para los estados de asistencia
enum EstadoAsistencia {
  P // Presente
  A // Ausente
  J // Justificado
}

// --- SEGURIDAD Y USUARIOS ---

enum Role {
  DIRECTORA
  EDUCADORA
  TECNICO
  ADMIN
}
enum TipoApoderado {
  TITULAR
  SUPLENTE
}

enum Parentesco {
  MADRE
  PADRE
  ABUELA_O
  TIA_O
  HERMANA_O
  OTRO
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  rut       String   @unique
  role      Role     @default(EDUCADORA)
  active    Boolean  @default(true)
  fotoUrl   String?  // URL de la foto de perfil
  
  // Relaciones para trazabilidad
  logs          AuditLog[]
  observaciones Observation[]
  asistencias   Asistencia[] @relation("RegistradoPor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MÓDULO IDENTIFICACIÓN (Relacional) ---

model Estudiante {
  id                        String   @id @default(uuid())
  rut                       String   @unique
  nombre                    String
  apellido                  String
  fechaNacimiento           DateTime
  direccion                 String
  estado                    Boolean  @default(true) 
  fechaIngreso              DateTime @default(now())
  vacunasAlDia              Boolean  @default(true)
  restriccionesAlimentarias String?
  alergias                  String?
  prevision                 String?

  // Relaciones Maestras
  tipoSangreId String
  tipoSangre   GrupoSanguineo @relation(fields: [tipoSangreId], references: [id])

  comunaId String
  comuna   Comuna @relation(fields: [comunaId], references: [id])

  nivelId String
  nivel   Nivel @relation(fields: [nivelId], references: [id])

  sexoId String
  sexo   Sexo @relation(fields: [sexoId], references: [id])
  
  nacionalidadId String
  nacionalidad Nacionalidad @relation(fields: [nacionalidadId], references: [id])

  // Relaciones de Módulos
  apoderados    EstudianteApoderado[]
  asistencias   Asistencia[]
  observaciones Observation[]
  evaluaciones  Evaluacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Apoderado {
  id              String                @id @default(uuid())
  nombreApoderado String
  rutApoderado    String                @unique
  telefono        String
  emailApoderado  String
  estudiantes     EstudianteApoderado[]
}

model EstudianteApoderado {
  id            String        @id @default(uuid())
  estudianteId  String
  apoderadoId   String
  tipoApoderado TipoApoderado
  parentesco    Parentesco
  prioridad     Int

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
  apoderado  Apoderado  @relation(fields: [apoderadoId], references: [id])

  @@unique([estudianteId, prioridad])
}

// --- TABLAS MAESTRAS ---

model GrupoSanguineo {
  id          String       @id @default(uuid())
  grupo       String
  estudiantes Estudiante[]
}

model Comuna {
  id          String       @id @default(uuid())
  comuna      String
  estudiantes Estudiante[]
}

model Nacionalidad {
  id          String       @id @default(uuid())
  nacionalidad String
  estudiantes Estudiante[]
}

model Nivel {
  id          String       @id @default(uuid())
  nivel       String
  estudiantes Estudiante[]
}

model Sexo {
  id          String       @id @default(uuid())
  genero      String
  estudiantes Estudiante[]
}

// --- MÓDULO ASISTENCIA ---

model Asistencia {
  id           String           @id @default(uuid())
  fecha        DateTime         @default(now())
  jornada      String           // "MAÑANA" o "TARDE"
  
  // Cambio: Ahora usamos el Enum P, A, J
  estado       EstadoAsistencia @default(P)
  
  // Nuevo: Para la validación del jefe de "cerrar la jornada"
  cerrado      Boolean          @default(false)
  
  // Nuevo: Campo opcional para justificar la inasistencia
  comentario   String?

  estudianteId String
  estudiante   Estudiante       @relation(fields: [estudianteId], references: [id])
  
  usuarioId    String
  registradoPor User             @relation("RegistradoPor", fields: [usuarioId], references: [id])

  @@unique([estudianteId, fecha, jornada]) 
}

// --- MÓDULO PEDAGÓGICO Y EVALUACIÓN ---

model Planificacion {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String
  tipo        String   // Sectorial, Anual, Transversal
  archivoUrl  String?  // Link al PDF/Doc en Cloudinary o AWS S3
  fechaInicio DateTime
  fechaFin    DateTime

  createdAt DateTime @default(now())
}

model Evaluacion {
  id           String   @id @default(uuid())
  tipo         String   // Diagnóstico, Bitácora, Escala
  resultado    Json     // Guardamos la escala o progreso como JSON flexible
  comentario   String?
  
  estudianteId String
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])

  createdAt DateTime @default(now())
}

// --- LIBRO DE VIDA (Anécdotas/Observaciones) ---

model Observation {
  id           String   @id @default(uuid())
  contenido    String   @db.Text
  tipo         String   // Positiva, Conductual, Salud
  
  estudianteId String
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
  
  autorId      String
  autor        User       @relation(fields: [autorId], references: [id])

  // Firma electrónica simple (podría ser un hash del registro)
  signatureHash String? 

  createdAt DateTime @default(now())
}

// --- SEGURIDAD: HUELLA DE AUDITORÍA (Audit Log) ---

model AuditLog {
  id        String   @id @default(uuid())
  accion    String   // "CREATE", "UPDATE", "DELETE"
  tabla     String   // Ejemplo: "Asistencia"
  registroId String  // El ID del registro afectado
  detalles  Json?    // Datos anteriores vs nuevos
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}