// Configuración básica
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql" // O mysql según tu preferencia
  //url      = env("DATABASE_URL")
}

// Agregamos este bloque para los estados de asistencia
enum EstadoAsistencia {
  P // Presente
  A // Ausente
  J // Justificado
}

// --- SEGURIDAD Y USUARIOS ---

enum Role {
  DIRECTORA
  EDUCADORA
  TECNICO
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  rut       String   @unique
  role      Role     @default(EDUCADORA)
  active    Boolean  @default(true)
  fotoUrl   String?  // URL de la foto de perfil
  
  // Relaciones para trazabilidad
  logs          AuditLog[]
  observaciones Observation[]
  asistencias   Asistencia[] @relation("RegistradoPor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MÓDULO IDENTIFICACIÓN (Ficha del Niño) ---

model Estudiante {
  id                    String    @id @default(uuid())
  
  // Identificación
  rut                   String    @unique
  nombre                String
  apellido              String
  sexo                  String    // O puedes usar Enum (MASCULINO, FEMENINO)
  fechaNacimiento       DateTime
  nacionalidad          String    @default("Chilena")

  // Domicilio
  direccion             String
  comuna                String    @default("Melipilla")

  // Salud
  prevision             String?   // Fonasa, Isapre, etc.
  tipoSangre            String?
  alergias              String?
  restriccionesAliment  String?
  vacunasAlDia          Boolean   @default(true)

  // Apoderados
  nombreApoderado       String
  rutApoderado          String
  parentesco            String
  telefono              String
  emailApoderado        String?

  // Situación de Matrícula
  fechaIngreso          DateTime  @default(now())
  nivel                 Nivel     // Usamos el Enum definido abajo
  estado                Estado    @default(VIGENTE)

  // Relaciones
  asistencias     Asistencia[]
  observaciones   Observation[]
  evaluaciones    Evaluacion[]

  // Auditoría básica
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Enums para estandarizar opciones
enum Nivel {
  SALA_CUNA_MENOR
  SALA_CUNA_MAYOR
  NIVEL_MEDIO_MENOR
  NIVEL_MEDIO_MAYOR
}

enum Estado {
  VIGENTE
  RETIRADO
}

// --- MÓDULO ASISTENCIA ---

model Asistencia {
  id           String           @id @default(uuid())
  fecha        DateTime         @default(now())
  jornada      String           // "MAÑANA" o "TARDE"
  
  // Cambio: Ahora usamos el Enum P, A, J
  estado       EstadoAsistencia @default(P)
  
  // Nuevo: Para la validación del jefe de "cerrar la jornada"
  cerrado      Boolean          @default(false)
  
  // Nuevo: Campo opcional para justificar la inasistencia
  comentario   String?

  estudianteId String
  estudiante   Estudiante       @relation(fields: [estudianteId], references: [id])
  
  usuarioId    String
  registradoPor User             @relation("RegistradoPor", fields: [usuarioId], references: [id])

  @@unique([estudianteId, fecha, jornada]) 
}

// --- MÓDULO PEDAGÓGICO Y EVALUACIÓN ---

model Planificacion {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String
  tipo        String   // Sectorial, Anual, Transversal
  archivoUrl  String?  // Link al PDF/Doc en Cloudinary o AWS S3
  fechaInicio DateTime
  fechaFin    DateTime

  createdAt DateTime @default(now())
}

model Evaluacion {
  id           String   @id @default(uuid())
  tipo         String   // Diagnóstico, Bitácora, Escala
  resultado    Json     // Guardamos la escala o progreso como JSON flexible
  comentario   String?
  
  estudianteId String
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])

  createdAt DateTime @default(now())
}

// --- LIBRO DE VIDA (Anécdotas/Observaciones) ---

model Observation {
  id           String   @id @default(uuid())
  contenido    String   @db.Text
  tipo         String   // Positiva, Conductual, Salud
  
  estudianteId String
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
  
  autorId      String
  autor        User       @relation(fields: [autorId], references: [id])

  // Firma electrónica simple (podría ser un hash del registro)
  signatureHash String? 

  createdAt DateTime @default(now())
}

// --- SEGURIDAD: HUELLA DE AUDITORÍA (Audit Log) ---

model AuditLog {
  id        String   @id @default(uuid())
  accion    String   // "CREATE", "UPDATE", "DELETE"
  tabla     String   // Ejemplo: "Asistencia"
  registroId String  // El ID del registro afectado
  detalles  Json?    // Datos anteriores vs nuevos
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}